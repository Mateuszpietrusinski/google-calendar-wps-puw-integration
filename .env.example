# ─────────────────────────────────────────────────────────────────────────────
# ahe-sync configuration
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PUW connector (Moodle e-learning platform) ───────────────────────────────
# Omit both keys entirely to disable PUW sync.
PUW_USERNAME=
PUW_PASSWORD=

# ── WPS connector (zjazd timetable) ──────────────────────────────────────────
# Omit both keys entirely to disable WPS sync.
WPS_USERNAME=
WPS_PASSWORD=

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Path A (default): use the shared team app.
#   GOOGLE_CLIENT_ID is published in the repository.
#   GOOGLE_CLIENT_SECRET is distributed separately — never commit it.
# Path B (advanced / forks): supply your own OAuth app credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Token storage ─────────────────────────────────────────────────────────────
# Controls where your Google OAuth token is stored after the first-run consent.
# If not set, you will be prompted interactively on first run.
#
#   local  (default) — token saved to ~/.config/ahe-sync/token.json (chmod 600)
#                      daemon restarts without re-authorisation
#   memory            — token held in process memory only
#                      browser OAuth runs on every daemon restart
TOKEN_STORAGE=

# ── Google Calendar ───────────────────────────────────────────────────────────
# Calendar to write events into. Use "primary" for the student's default calendar.
GOOGLE_CALENDAR_ID=primary

# ── Polling schedule ──────────────────────────────────────────────────────────
# Minimum allowed value for PUW is 10 (enforced in code).
PUW_POLL_INTERVAL_MINUTES=10

# Comma-separated HH:MM times in Europe/Warsaw (CET/CEST).
WPS_POLL_TIMES_CET=12:00,21:00

# ── Per-event reminders (minutes before event; 0 = no reminder) ──────────────
REMINDER_LECTURE_MINUTES=30
REMINDER_DEADLINE_MINUTES=1440
REMINDER_EXAM_MINUTES=60
REMINDER_WPS_MINUTES=60

# ── WPS semester date override (auto-detected from API if not set) ────────────
# Use ISO date format: YYYY-MM-DD
WPS_SEMESTER_FROM=
WPS_SEMESTER_TO=
